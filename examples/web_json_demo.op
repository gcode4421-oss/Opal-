echo "\n=== 5. URL Encoding / ترميز URL ==="

var url = "https://example.com/search"
var query = "Opal programming language"
var encoded = url_encode(query)
echo "Original:", query
echo "Encoded:", encoded
echo "Full URL:", url + "?q=" + encoded

echo "\n=== 6. JSON-like Data Processing / معالجة البيانات ==="

// Simulate API response / محاكاة استجابة API
var api_response = {
    "status": "success",
    "data": {
        "users": [
            {"id": 1, "name": "User 1"},
            {"id": 2, "name": "User 2"},
            {"id": 3, "name": "User 3"}
        ],
        "total": 3
    }
}

if api_response["status"] == "success" {
    var data = api_response["data"]
    echo "Total users:", data["total"]

    var users = data["users"]
    echo "Users list:"
    for user in users {
        echo "  ID:", user["id"], "- Name:", user["name"]
    }
}

echo "\n=== Web & JSON demo complete! ==="
echo "اكتمل عرض الويب و JSON!"
